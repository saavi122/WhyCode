  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "GitHub OAuth Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"PASTE_GITHUB_OAUTH_CODE_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/github",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "github"
              ]
            },
            "description": "Exchanges a temporary GitHub OAuth code for an access token, registers/finds the user, and returns a JWT token."
          },
          "response": []
        },
        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Retrieves profile details of the currently logged-in user."
          },
          "response": []
        }
      ]
    },
